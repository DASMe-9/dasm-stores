# dasm-stores — متغيرات البيئة (نسخة مثال)
# انسخ إلى `.env.local` للتطوير المحلي؛ على Vercel تُضبط من Settings → Environment Variables.

# ── باكند المنصة (SSR، Server Actions، pages/api) ──
# الإنتاج الرسمي — لا تستخدم dasm-platform-backend (لا يخدم /api/login ولا /api/stores)
API_BACKEND_URL=https://api.dasm.com.sa
DASM_API_URL=https://api.dasm.com.sa
NEXT_PUBLIC_API_URL=https://api.dasm.com.sa

# ── نطاق الواجهة العامة (canonical، OG — lib/seo، lib/storefront-url) ──
NEXT_PUBLIC_STORE_DOMAIN=stores.dasm.com.sa

# ── تسجيل الدخول الاجتماعي (Google عبر تدفق Socialite redirect + Apple id_token) ──
# Google: انتقال علوي إلى ${NEXT_PUBLIC_API_URL}/api/auth/google/redirect ثم العودة لـ /auth/social/callback.
# علم إظهار الزر + تدفق Apple id_token. تُضبط على Vercel.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=

# ── DASM-services (Supabase) — جدول stores وبيانات المتجر التشغيلية ──
# المشروع: bmfqfmsxtotdksvcqfrh (DASM-services)
# المفتاح: service_role من Supabase Dashboard → Settings → API (server-only — لا NEXT_PUBLIC_*)
# ملاحظة: في dasm-souq الاسم SUPABASE_SERVICE_ROLE_KEY؛ هنا SUPABASE_SERVICES_SERVICE_KEY (نفس المفتاح).
SUPABASE_SERVICES_URL=https://bmfqfmsxtotdksvcqfrh.supabase.co
SUPABASE_SERVICES_SERVICE_KEY=

# ── Platform API (server-to-server مع باكند داسم) ──
DASM_PLATFORM_NAME=dasm-stores
DASM_PLATFORM_API_KEY=
